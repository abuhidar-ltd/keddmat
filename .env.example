# Production site origin (no trailing slash). Used for share links, Open Graph / Twitter image URLs at build time.
# Defaults to https://keddmat.com if unset.
# VITE_PUBLIC_SITE_URL=https://your-production-domain.com

# CliQ recipient alias shown in the payment modal (must match your real CliQ handle if the bank ID differs).
# VITE_CLIQ_ALIAS=your-cliq-alias
